# ==================== AI Routing (LiteLLM) ====================
AI_CHAT_ORDER=gemini,zhipu,azure
AI_SUMMARY_PROVIDER=gemini
# AI_SUMMARY_FALLBACK_PROVIDER=azure
AI_TRANSLATE_PROVIDER=zhipu
# AI_TRANSLATE_FALLBACK_PROVIDER=openai
AI_VISION_PROVIDER=zhipu
# AI_VISION_FALLBACK_PROVIDER=openai
AI_CLASSIFIER_PROVIDER=zhipu
# AI_CLASSIFIER_FALLBACK_PROVIDER=openai

# OpenAI API Configuration (LiteLLM)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_SUMMARY_MODEL=gpt-4o-mini
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# Google Gemini API Key (LiteLLM native provider: gemini/<model>)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Leave empty for Google AI Studio's default native endpoint.
GEMINI_API_BASE=
# Set true only when using an OpenAI-compatible Gemini proxy/base URL.
GEMINI_OPENAI_COMPATIBLE=false
GEMINI_CHAT_MODEL=gemini-3-flash-preview
GEMINI_CHAT_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_SUMMARY_MODEL=gemini-3-flash-preview
GEMINI_SUMMARY_FALLBACK_MODEL=gemini-2.5-flash-lite

# Azure OpenAI API Configuration (LiteLLM provider: azure/<deployment>)
# 获取地址: https://portal.azure.com/
AZURE_OPENAI_API_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=your_azure_deployment_name
AZURE_OPENAI_CHAT_MODEL=your_azure_deployment_name
# AZURE_OPENAI_SUMMARY_MODEL=your_azure_deployment_name
# AZURE_OPENAI_TRANSLATE_MODEL=your_azure_deployment_name
# AZURE_OPENAI_VISION_MODEL=your_azure_deployment_name
# AZURE_OPENAI_CLASSIFIER_MODEL=your_azure_deployment_name

# ZhipuAI API Key (LiteLLM provider: zai/<model>)
# 获取地址: https://open.bigmodel.cn/
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CHAT_MODEL=glm-4.5-flash
ZHIPU_TRANSLATE_MODEL=glm-4.5-flash
ZHIPU_VISION_MODEL=glm-4.1v-thinking-flash
ZHIPU_CLASSIFIER_MODEL=glm-4.5-flash
# ZHIPU_SUMMARY_MODEL=glm-4.5-flash

# Chat history token thresholds (optional)
# CHAT_TOKEN_WARN_LIMIT=95000
# CHAT_TOKEN_LIMIT=100000

# ==================== Telegram Bot ====================
# Telegram Bot Token
# 获取地址: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==================== Database Configuration ====================
# MySQL Database Settings
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=telegram_bot_db

# ==================== Search API ====================
# SerpApi Key (Google Search)
# 获取地址: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# ==================== Code Execution API ====================
# Judge0 API Key
# 获取地址: https://ce.judge0.com/
JUDGE0_API_KEY=your_judge0_api_key_here

# ==================== Image Generation API ====================
IMAGE_GEN_API_URL=
IMAGE_GEN_API_TOKEN=your_image_generation_api_token_here
